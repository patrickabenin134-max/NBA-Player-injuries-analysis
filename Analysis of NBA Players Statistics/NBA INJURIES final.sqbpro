alues/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Stats" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="60"/><column index="2" value="39"/><column index="3" value="140"/><column index="4" value="39"/><column index="5" value="39"/><column index="6" value="39"/><column index="7" value="39"/><column index="8" value="39"/><column index="9" value="39"/><column index="10" value="46"/><column index="11" value="46"/><column index="12" value="39"/><column index="13" value="46"/><column index="14" value="46"/><column index="15" value="46"/><column index="16" value="44"/><column index="17" value="43"/><column index="18" value="42"/><column index="19" value="43"/><column index="20" value="44"/><column index="21" value="45"/><column index="22" value="39"/><column index="23" value="39"/><column index="24" value="39"/><column index="25" value="39"/><column index="26" value="54"/><column index="27" value="46"/><column index="28" value="42"/><column index="29" value="41"/><column index="30" value="39"/><column index="31" value="40"/><column index="32" value="39"/><column index="33" value="39"/><column index="34" value="46"/><column index="35" value="39"/><column index="36" value="39"/><column index="37" value="39"/><column index="38" value="39"/><column index="39" value="39"/><column index="40" value="46"/><column index="41" value="46"/><column index="42" value="39"/><column index="43" value="39"/><column index="44" value="46"/><column index="45" value="39"/><column index="46" value="39"/><column index="47" value="39"/><column index="48" value="39"/><column index="49" value="39"/><column index="50" value="39"/><column index="51" value="39"/><column index="52" value="39"/><column index="53" value="39"/></column_widths><filter_values><column index="2" value="kobe"/></filter_values><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 2">WITH Player_evaluation AS (SELECT strftime('%Y', NBA_Injury.Date) AS Season , Player_data.ID AS ID, Player_data.Player AS Player, Stats.Pos AS Position, Stats.[G] AS games,
					CASE 
					WHEN Stats.Pos LIKE '%PG%' THEN Stats.[MP]
					WHEN Stats.Pos LIKE '%SG%' THEN Stats.[MP]
					WHEN Stats.Pos LIKE '%SF%' THEN Stats.[MP]
					WHEN Stats.Pos LIKE '%PF%' THEN Stats.[MP]
					WHEN Stats.Pos LIKE '%C%'  THEN Stats.[MP]
					WHEN Stats.Pos LIKE '%G%'  THEN Stats.[MP]
					WHEN Stats.Pos LIKE '%F%'  THEN Stats.[MP]
					ELSE NULL
						END as main_statistics, 
					CASE 
					WHEN Stats.Pos LIKE '%PG%' THEN Stats.[USG%]
					WHEN Stats.Pos LIKE '%SG%' THEN Stats.[USG%] 
					WHEN Stats.Pos LIKE '%SF%' THEN Stats.[USG%] 
					WHEN Stats.Pos LIKE '%PF%' THEN Stats.[TS%] 
					WHEN Stats.Pos LIKE '%C%'  THEN Stats.[TS%] 
					WHEN Stats.Pos LIKE '%G%'  THEN Stats.[USG%] 
					WHEN Stats.Pos LIKE '%F%'  THEN Stats.[USG%] 
					ELSE NULL
						END as second_main_statistics, 
					CASE 
					WHEN Stats.Pos LIKE '%PG%' THEN Stats.[TS%] 
					WHEN Stats.Pos LIKE '%SG%' THEN Stats.[TS%] 
					WHEN Stats.Pos LIKE '%SF%' THEN Stats.[TS%] 
					WHEN Stats.Pos LIKE '%PF%' THEN Stats.[TRB%] 
					WHEN Stats.Pos LIKE '%C%'  THEN Stats.[TRB%] 
					WHEN Stats.Pos LIKE '%G%'  THEN Stats.[TS%] 
					WHEN Stats.Pos LIKE '%F%'  THEN Stats.[TS%] 
					ELSE NULL
						END as third_main_statistics, 
		 
					CASE 
					WHEN Stats.Pos LIKE '%PG%' THEN Stats.[AST%] 
					WHEN Stats.Pos LIKE '%SG%' THEN Stats.[AST%] 
					WHEN Stats.Pos LIKE '%SF%' THEN Stats.[3P%] 
					WHEN Stats.Pos LIKE '%PF%' THEN Stats.[BLK%] 
					WHEN Stats.Pos LIKE '%C%'  THEN Stats.[BLK%] 
					WHEN Stats.Pos LIKE '%G%'  THEN Stats.[AST%] 
					WHEN Stats.Pos LIKE '%F%'  THEN Stats.[3P%] 
					ELSE NULL
						END as fourth_main_statistics, 
						
					CASE 
					WHEN Stats.Pos LIKE '%PG%' THEN Stats.[TOV%] 
					WHEN Stats.Pos LIKE '%SG%' THEN Stats.[TOV%] 
					WHEN Stats.Pos LIKE '%SF%' THEN Stats.[TRB%] 
					WHEN Stats.Pos LIKE '%PF%' THEN Stats.[ORB%] 
					WHEN Stats.Pos LIKE '%C%'  THEN Stats.[ORB%] 
					WHEN Stats.Pos LIKE '%G%'  THEN Stats.[TOV%] 
					WHEN Stats.Pos LIKE '%F%'  THEN Stats.[TRB%] 
					ELSE NULL
						END as fifth_main_statistics, 
					 
					CASE 
					WHEN Stats.Pos LIKE '%PG%' THEN Stats.[3P%] 
					WHEN Stats.Pos LIKE '%SG%' THEN Stats.[3P%]
					WHEN Stats.Pos LIKE '%SF%' THEN Stats.[STL%] 
					WHEN Stats.Pos LIKE '%PF%' THEN Stats.[FTr] 
					WHEN Stats.Pos LIKE '%C%'  THEN Stats.[FTr]
					WHEN Stats.Pos LIKE '%G%'  THEN Stats.[3P%] 
					WHEN Stats.Pos LIKE '%F%'  THEN Stats.[STL%] 
					ELSE NULL
						END as sixth_main_statistics, 
					
					CASE 
					WHEN Stats.Pos LIKE '%PG%' THEN Stats.[BPM]
					WHEN Stats.Pos LIKE '%SG%' THEN Stats.[BPM]
					WHEN Stats.Pos LIKE '%SF%' THEN Stats.[BPM]
					WHEN Stats.Pos LIKE '%PF%' THEN Stats.[BPM]
					WHEN Stats.Pos LIKE '%C%'  THEN Stats.[BPM]
					WHEN Stats.Pos LIKE '%G%'  THEN Stats.[BPM]
					WHEN Stats.Pos LIKE '%F%'  THEN Stats.[BPM]
					ELSE NULL
						END as seventh_main_statistics
					FROM NBA_Injury
					JOIN Player_data
					ON NBA_Injury.Relinquished = Player_data.Player
					JOIN Stats
					ON Player_data.Player = Stats.Player AND strftime('%Y', NBA_Injury.Date) = CAST(Stats.Year AS TEXT))

SELECT Season AS Year, ID, Player, COUNT(*) AS Injuries, Position,
					main_statistics, second_main_statistics, third_main_statistics, fourth_main_statistics, fifth_main_statistics, sixth_main_statistics,seventh_main_statistics,
					(main_statistics*7 + second_main_statistics*6 + third_main_statistics*5 + fourth_main_statistics*4 + fifth_main_statistics*3 + sixth_main_statistics*2 + seventh_main_statistics)/28 as score
FROM Player_evaluation
WHERE games &gt; 60


GROUP BY Year, ID
ORDER BY Injuries DESC
</sql><current_tab id="0"/></tab_sql></sqlb_project>
